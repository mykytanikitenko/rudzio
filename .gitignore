target
# Ignore everything in .cargo/ except audit.toml — that file carries
# the cargo-audit advisory ignore list and must be tracked so
# `just check-audit` behaves the same on every checkout. Cargo's own
# generated dirs (registry, git, credentials.toml) stay ignored.
.cargo/*
!.cargo/audit.toml
.idea
*.iml
.vscode
.claude
.DS_Store
8.md
# Shell env state created by the nix dev-shell ends up in the project
# dir; keep it out of the repo.
.cache
.config
.local

# bacon-ls and other bacon logs
*.log
