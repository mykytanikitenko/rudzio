# Copy to .config/.env and fill in. .config/ is gitignored.
# Every value is required. Missing = immediate error.
#
# Sourced by Justfile's `test` and `test-stock` recipes
# (`set -a && source .config/.env && set +a` if the file exists).

# ---------------------------------------------------------------------------
# crates.io publish token — used by `cargo publish` workflows once they
# exist. Not yet referenced by the CI workflow but kept here so the
# `.env` template matches what PorfiryPetrovich-ai/infra's .env declares
# (same operator setup pattern).
# ---------------------------------------------------------------------------
CARGO_REGISTRY_TOKEN=
